---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../db/supabase';
import { getEmbedData } from '../lib/videos';

const { data: rawVideos, error } = await supabase
  .from('videos')
  .select('*')
  .eq('is_active', true)
  .order('display_order', { ascending: true });

if (error) {
  console.error('Error fetching videos:', error);
}

const videos = (rawVideos || []).map((video: any) => ({
  ...video,
  embed: getEmbedData(video)
}));
---

<Layout title="Artisan Videos - Shreeyam Handicrafts" description="Watch artisan stories, Instagram reels, and craftsmanship videos from Shreeyam Handicrafts.">
    <section class="min-h-screen bg-white py-12 md:py-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="mb-10 md:mb-14 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
                <div>
                    <span class="inline-flex items-center rounded-full border border-stone-200 bg-stone-50 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.2em] text-stone-500">Video Library</span>
                    <h1 class="mt-4 text-4xl md:text-5xl font-playfair text-stone-900">All Artisan Videos</h1>
                    <p class="mt-3 max-w-2xl text-sm md:text-base text-stone-600">Browse every active video added from your admin panel. Tap any video to play it directly on the site.</p>
                </div>
                <a href="/" class="inline-flex items-center justify-center rounded-full border border-stone-300 px-5 py-3 text-sm font-medium text-stone-900 transition hover:bg-stone-900 hover:text-white">Back to Home</a>
            </div>

            {videos.length > 0 ? (
                <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
                    {videos.map((video: any, index: number) => (
                        <div class="overflow-hidden rounded-[2rem] border border-stone-200 bg-[#FDFBF7] shadow-sm transition hover:shadow-xl">
                            {video.embed.isInstagram ? (
                                <a href={video.embed.instagramPermalink || video.video_url} target="_blank" rel="noopener noreferrer" class="group block aspect-[9/16] overflow-hidden bg-stone-900 relative">
                                    <img src={video.embed.thumbnail} alt={video.title} class="h-full w-full object-cover transition duration-500 group-hover:scale-105" loading="lazy" />
                                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/15 to-black/10"></div>
                                    <div class="absolute left-4 top-4 flex items-center gap-2 rounded-full bg-white/15 px-3 py-1.5 text-[11px] font-bold uppercase tracking-[0.18em] text-white backdrop-blur">
                                        <span class="inline-flex h-2 w-2 rounded-full bg-pink-500"></span>
                                        Instagram Reel
                                    </div>
                                    <div class="absolute inset-0 flex items-center justify-center">
                                        <div class="flex h-16 w-16 items-center justify-center rounded-full bg-white/90 text-stone-900 shadow-lg transition group-hover:scale-110">
                                            <svg class="ml-1 h-7 w-7" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
                                        </div>
                                    </div>
                                    <div class="absolute inset-x-0 bottom-0 p-5 text-white">
                                        <div class="inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-stone-900">
                                            Watch on Instagram
                                        </div>
                                    </div>
                                </a>
                            ) : video.embed.isDirect ? (
                                <div class="aspect-[9/16] overflow-hidden bg-stone-900">
                                    <video src={video.video_url} poster={video.embed.thumbnail} class="h-full w-full object-cover" controls playsinline preload="metadata"></video>
                                </div>
                            ) : (
                                <a href={video.video_url} target="_blank" rel="noopener noreferrer" class="flex aspect-[9/16] items-center justify-center bg-stone-900 text-white">
                                    <span>Open in {video.embed.sourceLabel}</span>
                                </a>
                            )}

                            <div class="p-5 md:p-6">
                                <div class="flex items-center justify-between gap-3">
                                    <div class="flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.18em] text-stone-500">
                                        <span class="inline-flex h-2 w-2 rounded-full bg-red-500"></span>
                                        {video.embed.sourceLabel}
                                    </div>
                                    <span class="text-xs font-semibold text-stone-400">#{index + 1}</span>
                                </div>
                                <h2 class="mt-3 text-xl font-semibold text-stone-900">{video.title}</h2>
                                <p class="mt-2 text-sm leading-relaxed text-stone-600">{video.description || 'A craft story from our latest collection.'}</p>
                            </div>
                        </div>
                    ))}
                </div>
            ) : (
                <div class="rounded-[2rem] border border-stone-200 bg-[#FDFBF7] p-10 text-center">
                    <h2 class="text-2xl font-playfair text-stone-900">No videos available yet</h2>
                    <p class="mt-3 text-stone-600">Add videos from the admin panel and they will appear here automatically.</p>
                </div>
            )}
        </div>
    </section>
    
</Layout>
